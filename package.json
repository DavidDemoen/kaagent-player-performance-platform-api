{
  "name": "kaagent-player-performance-api",
  "version": "1.0.0",
  "description": "Backend API for the Kaagent Player Performance Platform",
  "author": "",
  "license": "UNLICENSED",
  "main": "dist/main.js",
  "exports": {
    "./club-database/schema": "./databases/club-database/schema.ts"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migrate:club": "drizzle-kit migrate --config drizzle/config/drizzle.club.config.ts",
    "db:migrate:evaluations": "drizzle-kit migrate --config drizzle/config/drizzle.evaluations.config.ts",
    "db:generate:club": "drizzle-kit generate --config drizzle/config/drizzle.club.config.ts",
    "db:generate:evaluations": "drizzle-kit generate --config drizzle/config/drizzle.evaluations.config.ts",
    "db:studio": "drizzle-kit studio",
    "db:setup": "sh scripts/database/setup-db.sh",
    "db:teardown": "sh scripts/database/teardown-db.sh",
    "db:destroy": "sh scripts/database/destroy-db.sh"
  },
  "dependencies": {
    "@mguay/nestjs-better-auth": "^1.0.4",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "axios": "^1.13.5",
    "better-auth": "^1.4.18",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "25.3.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.20.0",
    "esbuild-node-externals": "^1.14.0",
    "esbuild-register": "^3.5.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.20.0",
    "kaagent-player-performance-platform-shared-types": "^0.0.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.29.3"
}
